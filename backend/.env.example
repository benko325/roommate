# Backend environment variables. Copy to `.env` and fill in real values.

NODE_ENV=development
PORT=3000

# PostgreSQL connection string used by Prisma.
# Uses the local Postgres on port 5432 (roommate role + roommate database).
DATABASE_URL="postgresql://roommate:roommate@localhost:5432/roommate?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30

# Frontend origin (used to build invitation links)
FRONTEND_URL=http://localhost:5173
